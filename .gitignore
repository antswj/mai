# Secrets: never commit real keys. Only .env.example is allowed.
.env
.env.*
!.env.example

# Captured data (always-on listening + screen reads stay local only)
/data/
data/
*.sqlite
*.sqlite-*
*.db
*.db-*
*.jsonl

# Local private-term blocklist for the pre-commit hook (optional, never committed)
.private-terms

# Swift / SwiftPM build artifacts
.build/
.swiftpm/
Package.resolved
DerivedData/

# macOS / editor noise
*.xcuserstate
.DS_Store
*.swp

# promptfoo local output
.promptfoo/
Evals/output/

# Built app bundle (run ./make-app.sh locally; never committed)
Mai.app/
# Local capture caches and clips
*.aiff
*.wav
*.m4a
screenshots/
