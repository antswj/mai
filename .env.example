# Mai API keys. Copy this file to .env and paste your own keys on the exact
# lines below. .env is gitignored and must NEVER be committed.
#
# Each user brings their own keys. Your audio and screen reads go to your own
# provider accounts; nothing is shared and there is no telemetry.

# Anthropic (the default LLM provider: classifier and drafter).
ANTHROPIC_API_KEY=your-anthropic-key-here

# Groq (alternative OpenAI-compatible LLM provider; set providers.llm = "groq").
GROQ_API_KEY=your-groq-key-here

# Google Gemini (vision read of the screen; used by the live smoke test now).
GEMINI_API_KEY=your-gemini-key-here

# Google Places API (New) (nearby place lookup; enable "Places API (New)").
GOOGLE_PLACES_API_KEY=your-google-places-key-here

# Recruit Hot Pepper Gourmet (nearby restaurant lookup in Japan).
HOTPEPPER_API_KEY=your-hotpepper-key-here

# Soniox real-time speech-to-text (live transcription of mic and system audio).
SONIOX_API_KEY=your-soniox-key-here
